# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── PostgreSQL (choose one of the following formats) ─────────────────────────
# Option A — single connection string (recommended for cloud DBs)
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/fleet_engine

# Option B — individual variables (used if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=fleet_engine
# PGUSER=postgres
# PGPASSWORD=yourpassword

# Set DATABASE_SSL=true for Supabase, Neon, Railway, or AWS RDS
DATABASE_SSL=false

# Pool settings (optional overrides)
PG_POOL_MAX=20
PG_IDLE_MS=30000
PG_CONN_TIMEOUT_MS=5000

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_256_bit_random_secret_before_deploying_to_production

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Options: "gemini" | "openai" | "mock"
AI_PROVIDER=mock

# Gemini API Key — get one free at https://aistudio.google.com
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key — used when AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI call timeout (ms) and max retries before falling back to mock
AI_TIMEOUT_MS=15000
AI_MAX_RETRIES=2

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
